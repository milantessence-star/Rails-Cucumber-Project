<%# app/views/sessions/new.html.erb %>
<h2>Login</h2>

<%= form_with url: login_path, local: true do |f| %>
  <div>
    <%= f.label :email, "Email" %>
    <%= f.email_field :email %>
  </div>

  <div>
    <%= f.label :password, "Password" %>
    <%= f.password_field :password %>
  </div>

  <%= f.submit "Log in" %>
<% end %>

<% if flash[:alert] %>
  <p><%= flash[:alert] %></p>
<% end %>

<!-- Button -->
<button id="openModalBtn">Open Form</button>

<!-- Modal -->
<div id="modal" class="hidden fixed inset-0 bg-gray-800 bg-opacity-50 flex items-center justify-center">
  <div class="bg-white p-6 rounded shadow-lg">
    
    <h2 class="text-lg font-bold mb-4">New Post</h2>

    <%= form_with url: "/posts", method: :post do |f| %>
      <%= f.text_field :title, placeholder: "Title" %>
      <%= f.submit "Save" %>
    <% end %>

    <button onclick="document.getElementById('modal').classList.add('hidden')">
      Close
    </button>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", () => {
    document.getElementById("openModalBtn").addEventListener("click", () => {
      document.getElementById("modal").classList.remove("hidden")
    })
  })
</script>